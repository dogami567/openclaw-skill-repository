# Images
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.3.2
NAPCAT_IMAGE=mlikiowa/napcat-docker:latest
CLAWDBOT_IMAGE=ghcr.io/dogami567/clawdbot-exa:latest

# Host paths (can be relative or absolute)
# - On Windows, prefer forward slashes: D:/openclaw/data/...
OPENCLAW_CONFIG_DIR=./data/openclaw/config
OPENCLAW_WORKSPACE_DIR=./data/openclaw/workspace

# Optional: mount an extra host workdir into the agent workspace.
# - Set to an absolute path to expose your project directory to the agent.
# - Or keep it as a local folder under this stack.
OPENCLAW_HOST_WORKDIR=./data/workdir

# OpenClaw gateway
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_TOKEN=change-me

# NapCat (WebUI + OneBot 11)
NAPCAT_UID=0
NAPCAT_GID=0
NAPCAT_ACCOUNT=
NAPCAT_DATA_DIR=./data/napcat
NAPCAT_WEBUI_PORT=6099
NAPCAT_HTTP_PORT=6300
NAPCAT_WS_PORT=6301
NAPCAT_WEBUI_TOKEN=openclaw-napcat
NAPCAT_WEBUI_PREFIX=

# OneBot token (used by OpenClaw <-> NapCat)
ONEBOT_TOKEN=openclaw-napcat

# Clawdbot (optional; used for Exa web_search provider)
CLAWDBOT_CONFIG_DIR=./data/clawdbot/config
CLAWDBOT_WORKSPACE_DIR=./data/clawdbot/workspace
CLAWDBOT_GATEWAY_BIND=lan
CLAWDBOT_GATEWAY_PORT=28789
CLAWDBOT_BRIDGE_PORT=28790
CLAWDBOT_GATEWAY_TOKEN=change-me

# Model providers (optional, for Clawdbot)
CLAWDBOT_OPENAI_API_KEY=
CLAWDBOT_OPENAI_BASE_URL=
CLAWDBOT_OPENROUTER_API_KEY=
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# Exa (optional; either one is fine; EXA_API_KEYS supports comma-separated pool)
EXA_API_KEYS=
EXA_API_KEY=

